---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Projects from '../components/sections/Projects.astro';
import About from '../components/sections/About.astro';
import Contact from '../components/sections/Contact.astro';
---

<BaseLayout title="Luis Sagnay | Software Engineering">
	<Hero />
	<Projects />
	<About />
	<Contact />
</BaseLayout>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	if (!reduceMotion) {
		const items = document.querySelectorAll("[data-animate]");

		items.forEach((element) => {
			const animation = element.getAttribute("data-animate") ?? "fade-up";
			const delay = Number(element.getAttribute("data-delay") ?? 0);

			const from = {
				opacity: 0,
				y: animation === "fade-down" ? -28 : animation === "zoom" ? 0 : 28,
				x: animation === "fade-left" ? 28 : animation === "fade-right" ? -28 : 0,
				scale: animation === "zoom" ? 0.96 : 1,
			};

			gsap.fromTo(
				element,
				from,
				{
					opacity: 1,
					x: 0,
					y: 0,
					scale: 1,
					duration: 0.6,
					ease: "power2.out",
					delay,
					scrollTrigger: {
						trigger: element,
						start: "top 86%",
						once: true,
					},
				},
			);
		});
	}
</script>