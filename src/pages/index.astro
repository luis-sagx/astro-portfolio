---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Experience from '../components/sections/Experience.astro';
import Projects from '../components/sections/Projects.astro';
import Stack from '../components/sections/Stack.astro';
import About from '../components/sections/About.astro';
import Certifications from '../components/sections/Certifications.astro';
import Contact from '../components/sections/Contact.astro';
---

<BaseLayout title="Luis Sagnay | Software Engineering">
  <Hero />
  <Experience />
  <Projects />
  <Stack />
  <About />
  <Certifications />
  <Contact />
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    document.querySelectorAll<HTMLElement>('[data-animate]').forEach((el) => {
      gsap.fromTo(
        el,
        { opacity: 0, y: 24 },
        {
          opacity: 1,
          y: 0,
          duration: 0.6,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        },
      );
    });

    const keys = gsap.utils.toArray<HTMLElement>('#stack .key3');
    if (keys.length > 0) {
      ScrollTrigger.create({
        trigger: '#stack',
        start: 'top 70%',
        once: true,
        onEnter: () => {
          keys.forEach((key, index) => {
            gsap.delayedCall(0.4 + index * 0.035, () => {
              key.classList.add('is-pressed');
              gsap.delayedCall(0.12, () => key.classList.remove('is-pressed'));
            });
          });
        },
      });
    }
  }
</script>
