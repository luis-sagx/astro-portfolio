---
import type { Translation } from '../../i18n/types';
import SectionHeading from '../molecules/SectionHeading.astro';

interface Props {
  messages: Translation;
}

const { messages } = Astro.props;
---

<section id="about-me" class="bg-canvas px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-6xl">
    <SectionHeading letter="A" title={messages.aboutSection.title} />

    <div class="grid gap-12 lg:grid-cols-3" data-animate="fade-up">
      <div>
        <h3 class="font-mono text-label uppercase tracking-wide text-muted">{messages.aboutSection.education}</h3>
        <div class="mt-5 space-y-5">
          {messages.data.education.map((edu) => (
            <div class="border-t border-line pt-4">
              {edu.degree && <p class="text-heading font-bold text-ink">{edu.degree}</p>}
              <p class="mt-1 text-body text-muted">{edu.institution}</p>
              <p class="mt-1 font-mono text-label text-accent">{edu.period}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="font-mono text-label uppercase tracking-wide text-muted">{messages.aboutSection.languages}</h3>
        <ul class="mt-5">
          {messages.data.languages.map((language) => (
            <li class="flex items-baseline justify-between gap-4 border-t border-line py-3">
              <span class="font-medium text-ink">{language.name}</span>
              <span class="text-right font-mono text-label text-muted">{language.proficiency}</span>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-mono text-label uppercase tracking-wide text-muted">{messages.aboutSection.beyondCode}</h3>
        <p class="mt-5 border-t border-line pt-4 text-body text-muted">
          {messages.aboutSection.beyondCopy}
        </p>
        <p class="mt-4 font-mono text-label text-muted">{messages.aboutSection.beyondTags}</p>
      </div>
    </div>
  </div>
</section>
