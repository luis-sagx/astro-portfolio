---
import {
  COURSES,
  EDUCATION,
  LANGUAGES,
  SKILL_CATEGORIES,
} from '../../data/constants';
import Icon from '../atoms/Icon.astro';
import TechBadge from '../atoms/TechBadge.astro';
import { Code, Braces, Monitor, Server, HardDrive, Wrench, GraduationCap, Globe, Heart, Award, Dumbbell, BookOpen, Volleyball } from '@lucide/astro';

const providerIcons = import.meta.glob('../../assets/icons/providers/*.svg', {
  eager: true,
  query: '?url',
  import: 'default',
}) as Record<string, string>;

const providerIconMap = Object.fromEntries(
  Object.entries(providerIcons).map(([path, url]) => {
    const slug = path.split('/').pop()?.replace('.svg', '') ?? '';
    return [slug.toLowerCase(), url];
  }),
);

const getProviderInitials = (provider: string) =>
  provider
    .split(/\s+/)
    .map((word) => word[0])
    .join('')
    .slice(0, 2)
    .toUpperCase();

const coursesWithIcons = COURSES.map((course) => {
  const slug = (course.icon || course.provider)
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');

  return {
    ...course,
    providerIcon: providerIconMap[slug],
    providerInitials: getProviderInitials(course.provider),
  };
});
---

<section
  id="about-me"
  class="relative px-6 py-24 overflow-hidden bg-linear-to-br from-teal-100/50 via-gray-100 to-teal-100/50 dark:from-teal-950/50 dark:via-gray-950 dark:to-emerald-950/50"
>
  <!-- Floating decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 right-32 w-56 h-56 rounded-full bg-emerald-200/15 dark:bg-emerald-500/5 blur-3xl float-slow"></div>
    <div class="absolute bottom-32 left-20 w-72 h-72 rounded-full bg-teal-200/15 dark:bg-teal-500/5 blur-3xl float-medium"></div>
    <div class="absolute top-1/3 left-1/4 w-40 h-40 rounded-full bg-emerald-100/20 dark:bg-emerald-600/5 blur-2xl float-fast"></div>
  </div>

  <div class="relative max-w-6xl mx-auto">
    <div class="mb-20 text-center" data-animate="fade-down">
      <span class="text-sm font-semibold tracking-wider uppercase text-emerald-600 dark:text-emerald-400">Get to know me</span>
      <h2 class="text-4xl font-bold text-gray-900 lg:text-5xl dark:text-white font-display">
        About
        <span class="text-transparent bg-linear-to-r from-emerald-600 to-teal-600 dark:from-emerald-400 dark:to-teal-400 bg-clip-text">Me</span>
      </h2>
      <div class="w-24 h-1 mx-auto mt-4 rounded-full bg-linear-to-r from-emerald-500 to-teal-500" data-animate="scale" data-delay="0.2"></div>
    </div>

    <div class="mb-20" data-animate="fade-up" data-delay="0.1">
      <div class="flex items-center gap-3 mb-10">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-linear-to-br from-emerald-500 to-teal-500">
          <Code class="w-5 h-5 text-white" />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white font-display">Technical Skills</h3>
      </div>

      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
        {SKILL_CATEGORIES.map((category, idx) => (
          <div data-animate="fade-up" data-delay={String(0.1 + idx * 0.08)}>
            <div class="flex items-center gap-2 mb-4">
              {category.icon === 'code' && <Braces class="w-4 h-4 text-emerald-600 dark:text-emerald-400" />}
              {category.icon === 'desktop' && <Monitor class="w-4 h-4 text-emerald-600 dark:text-emerald-400" />}
              {category.icon === 'server' && <Server class="w-4 h-4 text-emerald-600 dark:text-emerald-400" />}
              {category.icon === 'database' && <HardDrive class="w-4 h-4 text-emerald-600 dark:text-emerald-400" />}
              {category.icon === 'wrench' && <Wrench class="w-4 h-4 text-emerald-600 dark:text-emerald-400" />}
              <h4 class="text-sm font-bold tracking-wide text-gray-500 uppercase dark:text-gray-400">{category.title}</h4>
            </div>
            <div class="flex flex-wrap gap-2">
              {category.skills.map((skill) => (
                <TechBadge name={skill.name} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="w-16 h-px mx-auto mb-20 bg-linear-to-r from-transparent via-emerald-400 to-transparent" data-animate="scale" data-delay="0.1"></div>

    <div class="grid gap-12 mb-20 lg:grid-cols-3">
      <div data-animate="fade-right" data-delay="0.1">
        <div class="flex items-center gap-3 mb-6">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-linear-to-br from-emerald-500 to-teal-500">
            <GraduationCap class="w-5 h-5 text-white" />
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white font-display">Education</h3>
        </div>
        <div class="space-y-5">
          {EDUCATION.map((edu) => (
            <div class="relative pl-5 border-l-2 border-emerald-300 dark:border-emerald-700">
              <div class="absolute w-3 h-3 rounded-full -left-1.75 top-1 bg-emerald-500"></div>
              {edu.degree && <p class="mb-3 text-lg font-semibold text-gray-900 dark:text-white">{edu.degree}</p>}
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{edu.institution}</p>
              <p class="mt-1 text-sm font-medium text-emerald-600 dark:text-emerald-400">{edu.period}</p>
            </div>
          ))}
        </div>
      </div>

      <div data-animate="fade-up" data-delay="0.2">
        <div class="flex items-center gap-3 mb-6">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-linear-to-br from-teal-500 to-emerald-500">
            <Globe class="w-5 h-5 text-white" />
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white font-display">Languages</h3>
        </div>
        <div class="space-y-4">
          {LANGUAGES.map((language) => (
            <div class="flex items-center justify-between p-3 border rounded-lg shadow-sm bg-white/80 border-gray-200/60 dark:bg-gray-900 dark:border-gray-800/50">
              <span class="font-medium text-gray-800 dark:text-gray-200">{language.name}</span>
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300">{language.proficiency}</span>
            </div>
          ))}
        </div>
      </div>

      <div data-animate="fade-left" data-delay="0.3">
        <div class="flex items-center gap-3 mb-6">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-linear-to-br from-emerald-500 to-teal-500">
            <Heart class="w-5 h-5 text-white" />
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white font-display">Beyond Code</h3>
        </div>
        <p class="mb-5 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
          In my free time, I enjoy staying active by playing sports and soccer. I also greatly value time with family and friends.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 border rounded-lg shadow-sm bg-white/80 border-gray-200/60 dark:bg-gray-900 dark:text-gray-300 dark:border-gray-800/50">
            <Volleyball class="w-4 h-4 text-emerald-500" />
            Soccer
          </span>
          <span class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 border rounded-lg shadow-sm bg-white/80 border-gray-200/60 dark:bg-gray-900 dark:text-gray-300 dark:border-gray-800/50">
            <Dumbbell class="w-4 h-4 text-emerald-500" />
            Exercise
          </span>
          <span class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 border rounded-lg shadow-sm bg-white/80 border-gray-200/60 dark:bg-gray-900 dark:text-gray-300 dark:border-gray-800/50">
            <BookOpen class="w-4 h-4 text-emerald-500" />
            Reading
          </span>
        </div>
      </div>
    </div>

    <div data-animate="fade-up" data-delay="0.1">
      <div class="flex items-center gap-3 mb-8">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-linear-to-br from-emerald-500 to-teal-500">
          <Award class="w-5 h-5 text-white" />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white font-display">Certifications</h3>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {coursesWithIcons.map((course, idx) => (
          <a
            href={course.certificateUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-animate="zoom"
            data-delay={String(idx * 0.06)}
            class="flex items-center gap-4 p-4 transition-all duration-200 border shadow-sm bg-white/80 border-gray-200/60 rounded-xl dark:bg-gray-900 dark:border-gray-800/50 hover:border-emerald-300 dark:hover:border-emerald-700 group hover:shadow-md"
          >
            {course.providerIcon ? (
              <img
                src={course.providerIcon}
                alt={`${course.provider} logo`}
                class="object-contain w-10 h-10 rounded-lg dark:bg-gray-100 p-0.5 shrink-0"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <span class="inline-flex items-center justify-center w-10 h-10 text-xs font-bold rounded-lg text-emerald-700 shrink-0 bg-emerald-100 dark:bg-emerald-900/40 dark:text-emerald-300">
                {course.providerInitials}
              </span>
            )}
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-800 truncate transition-colors dark:text-gray-200 group-hover:text-emerald-600 dark:group-hover:text-emerald-400">{course.title}</p>
              <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-500">{course.provider}</p>
            </div>
            <Icon name="external" className="w-4 h-4 text-gray-400 transition-colors group-hover:text-emerald-500" />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
