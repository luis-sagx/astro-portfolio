---
import type { Translation } from '../../i18n/types';
import Icon from '../atoms/Icon.astro';
import KeyButton from '../atoms/KeyButton.astro';
import SectionHeading from '../molecules/SectionHeading.astro';

interface Props {
  messages: Translation;
}

const { messages } = Astro.props;
const { contactInfo } = messages.data;
const socialLinks = contactInfo.socialLinks.filter((social) =>
  ['LinkedIn', 'GitHub'].includes(social.platform),
);

const socialIconMap: Record<string, 'linkedin' | 'github'> = {
  LinkedIn: 'linkedin',
  GitHub: 'github',
};
---

<section id="contact" class="bg-canvas px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      letter="@"
      title={messages.contactSection.title}
      sub={messages.contactSection.sub}
    />

    <div class="grid gap-12 lg:grid-cols-2" data-animate="fade-up">
      <div>
        <a
          href={`mailto:${contactInfo.email}`}
          class="break-all font-mono text-heading font-medium text-accent hover:underline"
        >
          {contactInfo.email}
        </a>
        <p class="mt-3 font-mono text-label text-muted">{contactInfo.location}</p>
        <div class="mt-8">
          <KeyButton href={`mailto:${contactInfo.email}`} variant="primary">{messages.contactSection.sendEmail}</KeyButton>
        </div>
      </div>

      <ul class="border-t border-line lg:border-t-0">
        {socialLinks.map((social) => (
          <li>
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.ariaLabel}
              class="group flex items-center justify-between border-b border-line py-4 transition-colors hover:bg-sunken "
            >
              <span class="flex items-center gap-3 font-medium text-ink group-hover:text-accent">
                <Icon name={socialIconMap[social.platform]} className="h-6 w-6 text-muted group-hover:text-accent" />
                {social.platform}
              </span>
              <span class="font-mono text-label text-accent">
                <svg class="h-5 w-5 shrink-0 text-muted group-hover:text-accent" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-astro-source-file="/home/luis/Desktop/ls/projects/portfolio/astro-portfolio/src/components/atoms/Icon.astro" data-astro-source-loc="88:4"><path d="M14 4h6v6M20 4l-9 9M5 8v11h11" data-astro-source-file="/home/luis/Desktop/ls/projects/portfolio/astro-portfolio/src/components/atoms/Icon.astro" data-astro-source-loc="89:6"></path></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
