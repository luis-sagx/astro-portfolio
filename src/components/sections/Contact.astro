---
import { CONTACT_INFO } from '../../data/constants';
import Icon from '../atoms/Icon.astro';
import KeyButton from '../atoms/KeyButton.astro';
import SectionHeading from '../molecules/SectionHeading.astro';

const socialLinks = CONTACT_INFO.socialLinks.filter((social) =>
  ['LinkedIn', 'GitHub'].includes(social.platform),
);

const socialIconMap: Record<string, 'linkedin' | 'github'> = {
  LinkedIn: 'linkedin',
  GitHub: 'github',
};
---

<section id="contact" class="bg-canvas px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      letter="@"
      title="Get in touch"
      sub="Open to internships, junior roles and interesting projects."
    />

    <div class="grid gap-12 lg:grid-cols-2" data-animate="fade-up">
      <div>
        <a
          href={`mailto:${CONTACT_INFO.email}`}
          class="break-all font-mono text-heading font-medium text-accent hover:underline"
        >
          {CONTACT_INFO.email}
        </a>
        <p class="mt-3 font-mono text-label text-muted">{CONTACT_INFO.location}</p>
        <div class="mt-8">
          <KeyButton href={`mailto:${CONTACT_INFO.email}`} variant="primary">Send an email</KeyButton>
        </div>
      </div>

      <ul class="border-t border-line lg:border-t-0">
        {socialLinks.map((social) => (
          <li>
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.ariaLabel}
              class="group flex items-center justify-between border-b border-line py-4 transition-colors hover:bg-sunken"
            >
              <span class="flex items-center gap-3 font-medium text-ink">
                <Icon name={socialIconMap[social.platform]} className="h-6 w-6 text-muted group-hover:text-accent" />
                {social.platform}
              </span>
              <span class="font-mono text-label text-accent">↗</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
