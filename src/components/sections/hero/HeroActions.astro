---
import Icon from '../../atoms/Icon.astro';

interface Props {
  resumeUrl: string;
}

const { resumeUrl } = Astro.props;
---

<div class="flex flex-col justify-center gap-4 pt-4 sm:flex-row lg:justify-start">
  <a
    href={resumeUrl}
    download="Luis_Sagnay_CV.pdf"
    class="flex items-center justify-center gap-2 px-8 py-4 font-semibold text-white transition-all duration-300 transform shadow-lg group bg-linear-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 rounded-xl hover:shadow-xl hover:-translate-y-1"
  >
    Download my CV
    <Icon name="download" className="w-5 h-5 text-white" />
  </a>

  <a
    href="#contact"
    class="flex items-center justify-center gap-2 px-8 py-4 font-semibold transition-all duration-300 transform bg-white border-2 shadow-md dark:bg-gray-800 text-emerald-600 dark:text-emerald-400 rounded-xl border-emerald-600 dark:border-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-950/30 hover:shadow-xl hover:-translate-y-1"
  >
    Get in Touch
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
      ></path>
    </svg>
  </a>
</div>
