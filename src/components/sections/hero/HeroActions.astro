---
interface Props {
  resumeUrl: string;
}

const { resumeUrl } = Astro.props;
---

<div class="flex flex-col justify-center gap-4 pt-4 sm:flex-row lg:justify-start">
  <a
    href={resumeUrl}
    download="Luis_Sagnay_CV.pdf"
    class="flex items-center justify-center gap-2 px-8 py-4 font-semibold text-white transition-all duration-300 transform shadow-lg group bg-linear-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 rounded-xl hover:shadow-xl hover:-translate-y-1"
  >
    Download my CV
    <svg
      class="w-6 h-6 text-white"
      fill="currentColor"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 640 640"
    >
      <path
        d="M352 96C352 78.3 337.7 64 320 64C302.3 64 288 78.3 288 96L288 306.7L246.6 265.3C234.1 252.8 213.8 252.8 201.3 265.3C188.8 277.8 188.8 298.1 201.3 310.6L297.3 406.6C309.8 419.1 330.1 419.1 342.6 406.6L438.6 310.6C451.1 298.1 451.1 277.8 438.6 265.3C426.1 252.8 405.8 252.8 393.3 265.3L352 306.7L352 96zM160 384C124.7 384 96 412.7 96 448L96 480C96 515.3 124.7 544 160 544L480 544C515.3 544 544 515.3 544 480L544 448C544 412.7 515.3 384 480 384L433.1 384L376.5 440.6C345.3 471.8 294.6 471.8 263.4 440.6L206.9 384L160 384zM464 440C477.3 440 488 450.7 488 464C488 477.3 477.3 488 464 488C450.7 488 440 477.3 440 464C440 450.7 450.7 440 464 440z"
      />
    </svg>
  </a>

  <a
    href="#contact"
    class="flex items-center justify-center gap-2 px-8 py-4 font-semibold transition-all duration-300 transform bg-white border-2 shadow-md dark:bg-gray-800 text-emerald-600 dark:text-emerald-400 rounded-xl border-emerald-600 dark:border-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-950/30 hover:shadow-xl hover:-translate-y-1"
  >
    Get in Touch
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
      ></path>
    </svg>
  </a>
</div>
