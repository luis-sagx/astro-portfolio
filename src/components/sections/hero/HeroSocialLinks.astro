---
import { CONTACT_INFO } from '../../../data/constants';
import Icon from '../../ui/Icon.astro';

const iconMap: Record<string, 'github' | 'linkedin'> = {
  github: 'github',
  linkedin: 'linkedin',
};

const links = CONTACT_INFO.socialLinks.filter((social) =>
  ['GitHub', 'LinkedIn'].includes(social.platform),
);
---

<div class="flex justify-center gap-4 pt-6 lg:justify-start">
  {links.map((social) => (
    <a
      href={social.url}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={social.ariaLabel}
      class="flex items-center justify-center w-12 h-12 text-gray-700 transition-all duration-300 bg-gray-200 rounded-full dark:bg-gray-800 dark:text-gray-300 hover:bg-emerald-100 dark:hover:bg-emerald-900/30 hover:text-emerald-600 dark:hover:text-emerald-400 hover:scale-110"
    >
      <Icon name={iconMap[social.icon] ?? 'github'} className="w-5 h-5" />
    </a>
  ))}
</div>
