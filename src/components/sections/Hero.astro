---
import { CONTACT_INFO } from '../../data/constants';
import { PERSONAL_INFO } from '../../data/constants/personal-info';
import Icon from '../atoms/Icon.astro';
import KeyButton from '../atoms/KeyButton.astro';

const fullName = `${PERSONAL_INFO.firstname} ${PERSONAL_INFO.lastname}`;
const socialIconMap: Record<string, 'github' | 'linkedin'> = {
  GitHub: 'github',
  LinkedIn: 'linkedin',
};
const socialLinks = CONTACT_INFO.socialLinks.filter((social) =>
  ['GitHub', 'LinkedIn'].includes(social.platform),
);
---

<section id="start" class="bg-canvas px-6 py-24 lg:py-32">
  <div class="mx-auto grid max-w-6xl items-center gap-14 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="order-2 lg:order-1" data-animate="fade-up">
      <p class="mb-5 font-mono text-label text-accent">{PERSONAL_INFO.status}</p>

      <h1 class="font-display text-display font-extrabold font-expanded text-ink">
        {PERSONAL_INFO.firstname}<br />{PERSONAL_INFO.lastname}
      </h1>

      <p class="mt-6 max-w-[62ch] text-body font-medium text-ink">
        {PERSONAL_INFO.profession} at ESPE. {PERSONAL_INFO.proofLine}
      </p>

      <p class="mt-4 max-w-[66ch] text-body text-muted">
        {PERSONAL_INFO.bio[2]}
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <KeyButton href="#projects" variant="primary">View projects</KeyButton>
        <KeyButton
          href={PERSONAL_INFO.resumeUrl ?? '/cv/Luis_Sagnay_CV.pdf'}
          variant="secondary"
          download="Luis_Sagnay_CV.pdf"
        >
          Download CV
        </KeyButton>
      </div>

      <ul class="mt-9 flex flex-wrap gap-x-6 gap-y-3 font-mono text-label text-muted">
        {socialLinks.map((social) => (
          <li>
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.ariaLabel}
              class="inline-flex items-center gap-2 transition-colors hover:text-accent"
            >
              <Icon name={socialIconMap[social.platform]} className="h-4 w-4" />
              {social.platform} ↗
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="order-1 lg:order-2" data-animate="fade-up">
      <div class="photo-plinth mx-auto max-w-sm">
        <img
          src={PERSONAL_INFO.imageUrl}
          alt={`${fullName} - Software Engineering student`}
          width="420"
          height="520"
          fetchpriority="high"
          class="aspect-[4/5] w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .photo-plinth {
    padding: 0.5rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow:
      0 8px 0 var(--key-edge),
      0 14px 24px oklch(0 0 0 / 0.12);
  }

  .photo-plinth img {
    border-radius: var(--radius-md);
    background: var(--sunken);
  }
</style>
