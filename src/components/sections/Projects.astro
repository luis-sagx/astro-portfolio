---
import { PROJECTS } from '../../data/constants';
import ProjectCard from '../organisms/ProjectCard.astro';
---

<section id="projects" class="relative px-6 py-20 overflow-hidden bg-gray-100 dark:bg-gray-950">
	<!-- Floating decorative orbs -->
	<div class="absolute inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-10 right-20 w-72 h-72 rounded-full bg-emerald-200/10 dark:bg-emerald-500/5 blur-3xl float-slow"></div>
		<div class="absolute bottom-20 left-10 w-96 h-96 rounded-full bg-teal-200/10 dark:bg-teal-500/5 blur-3xl float-medium"></div>
		<div class="absolute top-1/2 left-1/2 w-64 h-64 rounded-full bg-emerald-100/15 dark:bg-emerald-600/5 blur-2xl float-fast"></div>
	</div>

	<div class="relative mx-auto max-w-7xl">
		<div class="mb-16 text-center" data-animate="fade-down">
			<div class="inline-block mb-4">
				<span class="text-sm font-semibold tracking-wider uppercase text-emerald-600 dark:text-emerald-400">Portfolio</span>
			</div>
			<h2 class="mb-4 text-4xl font-bold text-gray-900 lg:text-5xl dark:text-white font-display">
				Featured
				<span class="text-transparent bg-linear-to-r from-emerald-600 to-teal-600 dark:from-emerald-400 dark:to-teal-400 bg-clip-text">Projects</span>
			</h2>
			<div class="w-24 h-1 mx-auto mt-4 rounded-full bg-linear-to-r from-emerald-500 to-teal-500" data-animate="scale" data-delay="0.2"></div>
		</div>

		<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
			{PROJECTS.map((project, index) => (
				<div data-animate="zoom" data-delay={String((index % 3) * 0.12)}>
					<ProjectCard
						title={project.title}
						description={project.description}
						image={project.image}
						github={project.githubUrl}
						link={project.link}
						tags={project.technologies}
						highlights={project.highlights}
					/>
				</div>
			))}
		</div>
	</div>
</section>