---
import { PROJECTS } from '../../data/constants';
import FeaturedProject from '../organisms/FeaturedProject.astro';
import ProjectRow from '../organisms/ProjectRow.astro';
import SectionHeading from '../molecules/SectionHeading.astro';

const featuredProjects = PROJECTS.slice(0, 2);
const moreProjects = PROJECTS.slice(2);
---

<section id="projects" class="bg-canvas px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      letter="P"
      title="Projects"
      sub="Work samples first, decoration never. Two featured builds, then a compact ledger of the rest."
    />

    <div>
      {featuredProjects.map((project, index) => (
        <FeaturedProject project={project} reverse={index % 2 === 1} />
      ))}
    </div>

    {moreProjects.length > 0 && (
      <ul class="mt-10 border-b border-line">
        {moreProjects.map((project) => <ProjectRow project={project} />)}
      </ul>
    )}
  </div>
</section>
