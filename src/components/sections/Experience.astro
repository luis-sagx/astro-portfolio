---
import type { Translation } from '../../i18n/types';
import Key3D from '../atoms/Key3D.astro';
import SectionHeading from '../molecules/SectionHeading.astro';

interface Props {
  messages: Translation;
}

const { messages } = Astro.props;
---

<section id="experience" class="bg-canvas px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      letter="E"
      title={messages.experienceSection.title}
    />

    <div class="border-y border-line">
      {messages.data.experience.map((item) => (
        <article class="grid gap-6 border-b border-line py-8 last:border-b-0 lg:grid-cols-[14rem_1fr]" data-animate="fade-up">
          <div>
            <p class="font-mono text-label text-accent">{item.period}</p>
            {item.status && <p class="mt-2 font-mono text-label text-muted">{item.status}</p>}
          </div>

          <div>
            <h3 class="text-heading font-bold text-ink">
              {item.role}{' '}
              <a href={item.companyUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">
                @ {item.company}
              </a>
            </h3>
            <p class="mt-3 max-w-[72ch] text-body text-muted">{item.summary}</p>

            <ul class="mt-5 space-y-3 text-body text-ink">
              {item.bullets.map((bullet) => (
                <li class="grid grid-cols-[1rem_1fr] gap-3">
                  <span class="mt-3 h-1.5 w-1.5 bg-accent" aria-hidden="true"></span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>

            <div class="mt-6 flex flex-wrap gap-2">
              {item.technologies.map((tech) => (
                <Key3D name={tech} mini />
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
