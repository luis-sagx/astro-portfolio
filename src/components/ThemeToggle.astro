---
import { Sun, Moon } from "@lucide/astro";
---

<button
  data-theme-toggle
  type="button"
  class="relative p-2.5 rounded-lg border border-emerald-300 hover:border-white dark:border-emerald-700 dark:hover:border-emerald-600 transition-all w-10 h-10 flex items-center justify-center group overflow-hidden hover:scale-105"
  aria-label="Toggle theme"
>
  <Sun
    class="absolute w-5 h-5 transition-all duration-500 scale-0 -rotate-90 opacity-0 dark:opacity-100 dark:rotate-0 dark:scale-100"
    color="white"
    stroke-width={2}
  />

  <Moon
    class="absolute w-5 h-5 transition-all duration-500 scale-100 rotate-0 opacity-100 dark:opacity-0 dark:rotate-90 dark:scale-0"
    color="white"
    stroke-width={2}
  />
</button>

<script is:inline>
  const html = document.documentElement;

  if (!html.hasAttribute("data-theme-toggle-bound")) {
    html.setAttribute("data-theme-toggle-bound", "true");

    const handleThemeToggle = (event) => {
      const target = event.target;

      if (!(target instanceof Element) || !target.closest("[data-theme-toggle]")) {
        return;
      }

      const isDark = html.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    };

    document.addEventListener("click", handleThemeToggle);
  }
</script>