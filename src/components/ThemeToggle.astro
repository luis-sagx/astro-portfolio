<button
  data-theme-toggle
  type="button"
  class="relative p-2.5 rounded-lg border border-emerald-300 hover:border-white dark:border-emerald-700 dark:hover:border-emerald-600 transition-all w-10 h-10 flex items-center justify-center group overflow-hidden hover:scale-105"
  aria-label="Toggle theme"
>
  <svg 
    class="absolute w-5 h-5 text-yellow-400 transition-all duration-500 scale-0 -rotate-90 opacity-0 dark:opacity-100 dark:rotate-0 dark:scale-100"
    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round"
      d="M12 3v1m0 18v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.364l-.707-.707M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
  </svg>
  
  <svg 
    class="absolute w-5 h-5 transition-all duration-500 scale-100 rotate-0 opacity-100 text-emerald-50 dark:opacity-0 dark:rotate-90 dark:scale-0"
    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
</button>

<script is:inline>
  const html = document.documentElement;

  if (!html.hasAttribute("data-theme-toggle-bound")) {
    html.setAttribute("data-theme-toggle-bound", "true");

    const handleThemeToggle = (event) => {
      const target = event.target;

      if (!(target instanceof Element) || !target.closest("[data-theme-toggle]")) {
        return;
      }

      const isDark = html.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    };

    document.addEventListener("click", handleThemeToggle);
  }
</script>