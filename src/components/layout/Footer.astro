---
import { CONTACT_INFO } from '../../data/constants';
import Icon from '../atoms/Icon.astro';

const currentYear = new Date().getFullYear();
const iconMap: Record<string, 'github' | 'linkedin'> = {
  github: 'github',
  linkedin: 'linkedin',
};
const links = CONTACT_INFO.socialLinks.filter((social) =>
  ['GitHub', 'LinkedIn'].includes(social.platform),
);
---

<footer class="border-t border-line bg-canvas px-6 py-12">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 md:flex-row md:items-end md:justify-between">
    <div>
      <h2 class="font-display text-heading font-extrabold font-expanded text-ink">Luis Sagnay</h2>
      <p class="mt-2 max-w-[54ch] text-muted">
        Software Engineering student building tactile web experiences, internal tools and automation workflows.
      </p>
      <p class="mt-4 font-mono text-label text-muted">© {currentYear} Luis Sagnay. All rights reserved.</p>
    </div>

    <div class="flex gap-5 font-mono text-label text-accent">
      {links.map((social) => (
        <a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.ariaLabel} class="inline-flex items-center gap-2 hover:underline">
          <Icon name={iconMap[social.icon] ?? 'github'} className="h-5 w-5" />
          {social.platform} ↗
        </a>
      ))}
    </div>
  </div>
</footer>
