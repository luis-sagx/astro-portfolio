---
import ThemeToggle from '../organisms/ThemeToggle.astro';

const NAV_ITEMS = [
  { name: 'Experience', href: '#experience' },
  { name: 'Projects', href: '#projects' },
  { name: 'Stack', href: '#stack' },
  { name: 'Contact', href: '#contact' },
];
---

<nav id="main-navbar" class="sticky top-0 bg-canvas/95 px-4 py-4 backdrop-blur-sm" style="z-index: var(--z-nav);">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 border-b border-line pb-4">
    <a href="#start" class="font-display text-heading font-extrabold font-expanded text-ink">
      Luis Sagnay
    </a>

    <button
      data-menu-button
      type="button"
      class="menu-key relative h-11 w-11 border border-line bg-key-center text-ink md:hidden"
      aria-label="Toggle navigation"
      aria-expanded="false"
    >
      <span class="menu-line top-[15px]"></span>
      <span class="menu-line top-[25px]"></span>
    </button>

    <div class="hidden items-center gap-7 md:flex">
      <ul class="flex items-center gap-7 font-mono text-label text-muted">
        {NAV_ITEMS.map((item) => (
          <li>
            <a href={item.href} class="transition-colors hover:text-accent">{item.name}</a>
          </li>
        ))}
      </ul>
      <ThemeToggle />
    </div>
  </div>

  <div data-mobile-menu class="hidden border-b border-line bg-canvas py-5 md:hidden">
    <ul class="mx-auto flex max-w-6xl flex-col gap-4 px-2 font-mono text-label text-ink">
      {NAV_ITEMS.map((item) => (
        <li>
          <a href={item.href} class="nav-link block py-2 transition-colors hover:text-accent">{item.name}</a>
        </li>
      ))}
      <li class="pt-2"><ThemeToggle /></li>
    </ul>
  </div>
</nav>

<style>
  .menu-key {
    border-radius: var(--radius-md);
    box-shadow: 0 3px 0 var(--key-edge);
    transition:
      transform 0.1s ease-out,
      box-shadow 0.1s ease-out;
  }

  .menu-key:active {
    transform: translateY(2px);
    box-shadow: 0 1px 0 var(--key-edge);
  }

  .menu-line {
    position: absolute;
    left: 11px;
    width: 20px;
    height: 2px;
    background: currentColor;
    transform-origin: center;
    transition:
      transform 0.18s ease-out,
      top 0.18s ease-out;
  }

  .menu-key[aria-expanded='true'] .menu-line:first-child {
    top: 20px;
    transform: rotate(45deg);
  }

  .menu-key[aria-expanded='true'] .menu-line:last-child {
    top: 20px;
    transform: rotate(-45deg);
  }
</style>

<script is:inline>
  const button = document.querySelector('[data-menu-button]');
  const menu = document.querySelector('[data-mobile-menu]');
  const links = document.querySelectorAll('.nav-link');

  let open = false;

  const syncState = () => {
    if (!menu || !button) return;
    menu.classList.toggle('hidden', !open);
    button.setAttribute('aria-expanded', String(open));
  };

  button?.addEventListener('click', () => {
    open = !open;
    syncState();
  });

  links.forEach((link) => {
    link.addEventListener('click', () => {
      open = false;
      syncState();
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768 && open) {
      open = false;
      syncState();
    }
  });
</script>
