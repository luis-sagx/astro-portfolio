---
import ThemeToggle from "../organisms/ThemeToggle.astro";

import { Menu } from "@lucide/astro";

const NAV_ITEMS = [
  { name: "Home", href: "#start" },
  { name: "Projects", href: "#projects" },
  { name: "About Me", href: "#about-me" },
  { name: "Contact", href: "#contact" },
];

---

<nav class="sticky top-0 z-50 shadow-lg bg-emerald-600 dark:bg-gray-800">
  <div class="flex items-center justify-between max-w-6xl px-6 py-4 mx-auto">
    
    <!-- Logo -->
    <a
      href="/"
      class="hidden text-xl font-bold text-white transition-colors duration-300 md:block font-display"
    >
      Luis Sagnay
    </a>

    <!-- Mobile button -->
    <button
      data-menu-button
      type="button"
      class="order-1 text-white md:hidden focus:outline-none"
      aria-label="Toggle navigation"
      aria-expanded="false"
    >
      <Menu />  
    </button>

    <!-- Menu -->
    <ul
      data-mobile-menu
      class="absolute left-0 z-40 flex-col hidden w-full gap-3 px-6 py-4 font-bold text-white transition-all duration-300 ease-in-out md:flex-row md:gap-8 md:flex md:static top-16 md:w-auto bg-emerald-600 dark:bg-gray-800 md:bg-transparent md:dark:bg-transparent md:p-0"
    >
      {NAV_ITEMS.map((item) => (
        <li>
          <a
            href={item.href}
            class="relative inline-block px-2 py-2 font-semibold text-white transition-colors duration-300 group nav-link dark:hover:text-emerald-400"
          >
            {item.name}
            <span class="absolute bottom-0 left-0 w-0 h-0.5 transition-all duration-300 bg-white dark:bg-emerald-400 group-hover:w-full"></span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Theme toggle desktop -->
    <div class="hidden ml-4 md:block">
      <ThemeToggle />
    </div>

    <!-- Theme toggle mobile -->
    <div class="order-3 block md:hidden">
      <ThemeToggle />
    </div>
  </div>
</nav>

<!-- Script -->
<script is:inline>
  const button = document.querySelector("[data-menu-button]");
  const menu = document.querySelector("[data-mobile-menu]");
  const links = document.querySelectorAll(".nav-link");

  let open = false;

  const syncState = () => {
    if (!menu || !button) {
      return;
    }

    menu.classList.toggle("hidden", !open);
    menu.classList.toggle("flex", open);
    button.setAttribute("aria-expanded", String(open));
  };

  button?.addEventListener("click", () => {
    open = !open;
    syncState();
  });

  links.forEach((link) => {
    link.addEventListener("click", () => {
      open = false;
      syncState();
    });
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768 && open) {
      open = false;
      syncState();
    }
  });
</script>