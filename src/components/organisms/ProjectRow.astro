---
import type { Project } from '../../data/models/portfolio.model';
import Icon from '../atoms/Icon.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<li>
  <article class="group grid gap-4 border-t border-line py-5 transition-colors hover:bg-sunken md:grid-cols-[1fr_auto] md:items-center" data-animate="fade-up">
    <div>
      <h3 class="font-semibold text-ink group-hover:text-accent">{project.title}</h3>
      <p class="mt-1 max-w-[68ch] text-muted">{project.description}</p>
    </div>

    <div class="flex flex-wrap items-center gap-4 font-mono text-label text-muted md:justify-end">
      <span>{project.technologies.slice(0, 3).join(' · ')}</span>
      {project.githubUrl && (
        <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-accent hover:underline">
          <Icon name="github" className="h-4 w-4" /> Code ↗
        </a>
      )}
    </div>
  </article>
</li>
