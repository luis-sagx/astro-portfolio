---
import { Moon, Sun } from '@lucide/astro';
---

<button
  data-theme-toggle
  type="button"
  class="theme-key relative flex h-11 w-11 items-center justify-center overflow-hidden border border-line bg-key-center text-ink"
  aria-label="Toggle theme"
>
  <Sun
    class="absolute h-5 w-5 scale-0 -rotate-90 opacity-0 transition-all duration-300 dark:scale-100 dark:rotate-0 dark:opacity-100"
    stroke-width={1.8}
  />
  <Moon
    class="absolute h-5 w-5 scale-100 rotate-0 opacity-100 transition-all duration-300 dark:scale-0 dark:rotate-90 dark:opacity-0"
    stroke-width={1.8}
  />
</button>

<style>
  .theme-key {
    border-radius: var(--radius-md);
    box-shadow:
      0 3px 0 var(--key-edge),
      0 5px 8px oklch(0 0 0 / 0.12);
    transition:
      transform 0.1s ease-out,
      box-shadow 0.1s ease-out;
  }

  .theme-key:hover {
    transform: translateY(1px);
    box-shadow:
      0 2px 0 var(--key-edge),
      0 3px 5px oklch(0 0 0 / 0.12);
  }

  .theme-key:active {
    transform: translateY(2px);
    box-shadow: 0 1px 0 var(--key-edge);
  }

  .theme-key:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
</style>

<script is:inline>
  const html = document.documentElement;

  if (!html.hasAttribute('data-theme-toggle-bound')) {
    html.setAttribute('data-theme-toggle-bound', 'true');

    const handleThemeToggle = (event) => {
      const target = event.target;

      if (!(target instanceof Element) || !target.closest('[data-theme-toggle]')) {
        return;
      }

      const isDark = html.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    };

    document.addEventListener('click', handleThemeToggle);
  }
</script>
