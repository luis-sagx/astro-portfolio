---
interface Props {
  letter?: string;
  title: string;
  sub?: string;
}

const { title, sub } = Astro.props;
---

<header class="mb-14" data-animate="fade-up">
  <h2 class="font-display text-title font-extrabold font-expanded text-ink">{title}</h2>
  {sub && <p class="mt-2 max-w-[70ch] text-body text-muted">{sub}</p>}
</header>
