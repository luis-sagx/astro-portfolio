---
import { Icon } from 'astro-icon/components';
import { resolveTechAssetSlug, resolveTechIcon } from '../../utils/tech-icons';

interface Props {
  name: string;
  size?: number;
  className?: string;
  forceWhite?: boolean;
}

const { name, size = 20, className = '', forceWhite = false } = Astro.props;

const techIcon = resolveTechIcon(name);
const techSlug = resolveTechAssetSlug(name);
const localTechIcons = import.meta.glob('../../assets/icons/tech/*.svg', {
  eager: true,
  query: '?url',
  import: 'default',
}) as Record<string, string>;

const localTechIconMap = Object.fromEntries(
  Object.entries(localTechIcons).map(([path, url]) => {
    const slug = path.split('/').pop()?.replace('.svg', '') ?? '';
    return [slug.toLowerCase(), url];
  }),
);

const localIconUrl = localTechIconMap[techSlug.toLowerCase()];
const fallbackText = name
  .split(/\s+/)
  .map((part) => part[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();

const whiteFilterStyle = forceWhite
  ? 'filter: brightness(0) saturate(100%) invert(100%);'
  : undefined;
---

{techIcon ? (
  <span class={`inline-flex items-center justify-center ${className}`} style={whiteFilterStyle}>
    <Icon name={techIcon} size={size} />
  </span>
) : localIconUrl ? (
  <img
    src={localIconUrl}
    alt={`${name} icon`}
    class={`inline-block object-contain ${className}`}
    style={whiteFilterStyle}
    width={size}
    height={size}
    loading="lazy"
    decoding="async"
  />
) : (
  <span
    class={`inline-flex items-center justify-center rounded-md bg-gray-200 text-[10px] font-bold text-gray-700 dark:bg-gray-800 dark:text-gray-200 ${className}`}
    style={`width:${size}px;height:${size}px;`}
    aria-hidden="true"
  >
    {fallbackText}
  </span>
)}
