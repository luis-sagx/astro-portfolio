---
import TechIcon from './TechIcon.astro';

interface Props {
  name: string;
}

const { name } = Astro.props;
---

<span class="inline-flex items-center gap-2 px-2.5 py-1.5 text-xs font-semibold text-gray-700 border rounded-lg bg-white/80 border-gray-200/70 dark:bg-gray-900 dark:text-gray-300 dark:border-gray-800/60">
  <TechIcon name={name} size={14} className="shrink-0" />
  <span>{name}</span>
</span>
