---
import { Icon } from 'astro-icon/components';
import { resolveTechAssetSlug, resolveTechIcon } from '../../utils/tech-icons';

interface Props {
  name: string;
  size?: number;
  className?: string;
  forceWhite?: boolean;
}

const { name, size = 20, className = '', forceWhite = false } = Astro.props;

const techIcon = resolveTechIcon(name);
const techSlug = resolveTechAssetSlug(name);
const localTechIcons = import.meta.glob('../../assets/icons/tech/*.svg', {
  eager: true,
  query: '?url',
  import: 'default',
}) as Record<string, string>;

const localTechIconMap = Object.fromEntries(
  Object.entries(localTechIcons).map(([path, url]) => {
    const slug = path.split('/').pop()?.replace('.svg', '') ?? '';
    return [slug.toLowerCase(), url];
  }),
);

const localIconUrl = localTechIconMap[techSlug.toLowerCase()];
const whiteFilterStyle = forceWhite
  ? 'filter: brightness(0) saturate(100%) invert(100%);'
  : undefined;

const customIconBySlug: Record<string, string> = {
  astro: 'M12 2.5 4.6 20.5h4.1l1-2.9h4.6l1 2.9h4.1L12 2.5Zm0 6.2 1.4 4.6h-2.8L12 8.7Zm-4.2 12.1c1.5 1.4 2.9 2 4.2 2s2.7-.6 4.2-2c-.8 2-2.2 3.2-4.2 3.2s-3.4-1.2-4.2-3.2Z',
  jhipster: 'M4 4h16v8.5c0 4.4-3.2 7.5-8 7.5s-8-3.1-8-7.5V4Zm4 3v5.7c0 2.4 1.6 4.1 4 4.1s4-1.7 4-4.1V7h-3v5.5c0 .8-.4 1.3-1 1.3s-1-.5-1-1.3V7H8Z',
  cicd: 'M7 7h9.5l-2-2L16 3l5.5 5.5L16 14l-1.5-2 2-2H7a3 3 0 0 0 0 6h1v3H7A6 6 0 0 1 7 7Zm10 10H7.5l2 2L8 21l-5.5-5.5L8 10l1.5 2-2 2H17a3 3 0 0 0 0-6h-1V5h1a6 6 0 0 1 0 12Z',
  backstage: 'M4 5h16v14H4V5Zm3 3v8h10V8H7Zm2 2h6v4H9v-4Z',
  n8n: 'M5.5 12a2.5 2.5 0 1 1 2.2-3.7l3.2 1.8a2.5 2.5 0 0 1 4.2 0l1.2-.7A2.5 2.5 0 1 1 17.5 12c-.5 0-1-.1-1.4-.4l-1.2.7a2.5 2.5 0 0 1-4.2 0l-3.2 1.8A2.5 2.5 0 0 1 5.5 12Zm0-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm7.5-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm5.5-1.7a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z',
  automation: 'M12 2l1.2 3.2 3.3.4-2.4 2.2.7 3.2L12 9.4 9.2 11l.7-3.2-2.4-2.2 3.3-.4L12 2Zm0 9a5 5 0 1 1-5 5 5 5 0 0 1 5-5Zm0 3a2 2 0 1 0 2 2 2 2 0 0 0-2-2Z',
};

const customPath = customIconBySlug[techSlug.toLowerCase()];
---

{techIcon ? (
  <span class={`inline-flex items-center justify-center ${className}`} style={whiteFilterStyle}>
    <Icon name={techIcon} size={size} />
  </span>
) : localIconUrl ? (
  <img
    src={localIconUrl}
    alt={`${name} icon`}
    class={`inline-block object-contain ${className}`}
    style={whiteFilterStyle}
    width={size}
    height={size}
    loading="lazy"
    decoding="async"
  />
) : customPath ? (
  <svg
    class={className}
    width={size}
    height={size}
    viewBox="0 0 24 24"
    aria-hidden="true"
    fill="currentColor"
  >
    <path d={customPath} />
  </svg>
) : (
  <svg
    class={className}
    width={size}
    height={size}
    viewBox="0 0 24 24"
    aria-hidden="true"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M4 7h16M4 12h16M4 17h10" />
  </svg>
)}
