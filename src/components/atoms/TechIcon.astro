---
import { Icon } from 'astro-icon/components';
import { resolveTechAssetSlug, resolveTechIcon } from '../../utils/tech-icons';

interface Props {
  name: string;
  size?: number;
  className?: string;
  forceWhite?: boolean;
}

const { name, size = 20, className = '', forceWhite = false } = Astro.props;

const techIcon = resolveTechIcon(name);
const techSlug = resolveTechAssetSlug(name).toLowerCase();
const localTechIcons = import.meta.glob('../../assets/icons/tech/*.svg', {
  eager: true,
  query: '?url',
  import: 'default',
}) as Record<string, string>;

const localTechIconMap = Object.fromEntries(
  Object.entries(localTechIcons).map(([path, url]) => {
    const slug = path.split('/').pop()?.replace('.svg', '') ?? '';
    return [slug.toLowerCase(), url];
  }),
);

const localIconUrl = localTechIconMap[techSlug];
const whiteFilterStyle = forceWhite
  ? 'filter: brightness(0) saturate(100%) invert(100%);'
  : undefined;

const customIconBySlug: Record<string, string> = {
  jhipster: 'M4 4h16v8.5c0 4.4-3.2 7.5-8 7.5s-8-3.1-8-7.5V4Zm4 3v5.7c0 2.4 1.6 4.1 4 4.1s4-1.7 4-4.1V7h-3v5.5c0 .8-.4 1.3-1 1.3s-1-.5-1-1.3V7H8Z',
  cicd: 'M7 7h9.5l-2-2L16 3l5.5 5.5L16 14l-1.5-2 2-2H7a3 3 0 0 0 0 6h1v3H7A6 6 0 0 1 7 7Zm10 10H7.5l2 2L8 21l-5.5-5.5L8 10l1.5 2-2 2H17a3 3 0 0 0 0-6h-1V5h1a6 6 0 0 1 0 12Z',
  backstage: 'M4 5h16v14H4V5Zm3 3v8h10V8H7Zm2 2h6v4H9v-4Z',
  automation: 'M12 2l1.2 3.2 3.3.4-2.4 2.2.7 3.2L12 9.4 9.2 11l.7-3.2-2.4-2.2 3.3-.4L12 2Zm0 9a5 5 0 1 1-5 5 5 5 0 0 1 5-5Zm0 3a2 2 0 1 0 2 2 2 2 0 0 0-2-2Z',
};

const customPath = customIconBySlug[techSlug];
const useCustomBrandIcon = ['n8n', 'meta', 'gitlab'].includes(techSlug);
---

{useCustomBrandIcon && techSlug === 'n8n' ? (
  <svg class={className} width={size} height={size} viewBox="0 0 228 120" aria-hidden="true">
    <path
      fill-rule="evenodd"
      clip-rule="evenodd"
      d="M204 48C192.817 48 183.42 40.3514 180.756 30H153.248C147.382 30 142.376 34.241 141.412 40.0272L140.425 45.9456C139.489 51.5648 136.646 56.4554 132.626 60C136.646 63.5446 139.489 68.4352 140.425 74.0544L141.412 79.9728C142.376 85.759 147.382 90 153.248 90H156.756C159.42 79.6486 168.817 72 180 72C193.255 72 204 82.7452 204 96C204 109.255 193.255 120 180 120C168.817 120 159.42 112.351 156.756 102H153.248C141.516 102 131.504 93.5181 129.575 81.9456L128.588 76.0272C127.624 70.241 122.618 66 116.752 66H107.244C104.58 76.3514 95.183 84 84 84C72.817 84 63.4204 76.3514 60.7561 66H47.2439C44.5796 76.3514 35.183 84 24 84C10.7452 84 0 73.2548 0 60C0 46.7452 10.7452 36 24 36C35.183 36 44.5796 43.6486 47.2439 54H60.7561C63.4204 43.6486 72.817 36 84 36C95.183 36 104.58 43.6486 107.244 54H116.752C122.618 54 127.624 49.759 128.588 43.9728L129.575 38.0544C131.504 26.4819 141.516 18 153.248 18L180.756 18C183.42 7.64864 192.817 0 204 0C217.255 0 228 10.7452 228 24C228 37.2548 217.255 48 204 48ZM204 36C210.627 36 216 30.6274 216 24C216 17.3726 210.627 12 204 12C197.373 12 192 17.3726 192 24C192 30.6274 197.373 36 204 36ZM24 72C30.6274 72 36 66.6274 36 60C36 53.3726 30.6274 48 24 48C17.3726 48 12 53.3726 12 60C12 66.6274 17.3726 72 24 72ZM96 60C96 66.6274 90.6274 72 84 72C77.3726 72 72 66.6274 72 60C72 53.3726 77.3726 48 84 48C90.6274 48 96 53.3726 96 60ZM192 96C192 102.627 186.627 108 180 108C173.373 108 168 102.627 168 96C168 89.3726 173.373 84 180 84C186.627 84 192 89.3726 192 96Z"
      fill="#ea4b71"
    />
  </svg>
) : useCustomBrandIcon && techSlug === 'meta' ? (
  <svg class={className} width={size} height={size} preserveAspectRatio="xMidYMid" viewBox="0 0 256 171" aria-hidden="true">
    <defs>
      <linearGradient id="meta__a" x1="13.878%" x2="89.144%" y1="55.934%" y2="58.694%">
        <stop offset="0%" stop-color="#0064E1" />
        <stop offset="40%" stop-color="#0064E1" />
        <stop offset="83%" stop-color="#0073EE" />
        <stop offset="100%" stop-color="#0082FB" />
      </linearGradient>
      <linearGradient id="meta__b" x1="54.315%" x2="54.315%" y1="82.782%" y2="39.307%">
        <stop offset="0%" stop-color="#0082FB" />
        <stop offset="100%" stop-color="#0064E0" />
      </linearGradient>
    </defs>
    <path fill="#0081FB" d="M27.651 112.136c0 9.775 2.146 17.28 4.95 21.82 3.677 5.947 9.16 8.466 14.751 8.466 7.211 0 13.808-1.79 26.52-19.372 10.185-14.092 22.186-33.874 30.26-46.275l13.675-21.01c9.499-14.591 20.493-30.811 33.1-41.806C161.196 4.985 172.298 0 183.47 0c18.758 0 36.625 10.87 50.3 31.257C248.735 53.584 256 81.707 256 110.729c0 17.253-3.4 29.93-9.187 39.946-5.591 9.686-16.488 19.363-34.818 19.363v-27.616c15.695 0 19.612-14.422 19.612-30.927 0-23.52-5.484-49.623-17.564-68.273-8.574-13.23-19.684-21.313-31.907-21.313-13.22 0-23.859 9.97-35.815 27.75-6.356 9.445-12.882 20.956-20.208 33.944l-8.066 14.289c-16.203 28.728-20.307 35.271-28.408 46.07-14.2 18.91-26.324 26.076-42.287 26.076-18.935 0-30.91-8.2-38.325-20.556C2.973 139.413 0 126.202 0 111.148l27.651.988Z" />
    <path fill="url(#meta__a)" d="M21.802 33.206C34.48 13.666 52.774 0 73.757 0 85.91 0 97.99 3.597 110.605 13.897c13.798 11.261 28.505 29.805 46.853 60.368l6.58 10.967c15.881 26.459 24.917 40.07 30.205 46.49 6.802 8.243 11.565 10.7 17.752 10.7 15.695 0 19.612-14.422 19.612-30.927l24.393-.766c0 17.253-3.4 29.93-9.187 39.946-5.591 9.686-16.488 19.363-34.818 19.363-11.395 0-21.49-2.475-32.654-13.007-8.582-8.083-18.615-22.443-26.334-35.352l-22.96-38.352C118.528 64.08 107.96 49.73 101.845 43.23c-6.578-6.988-15.036-15.428-28.532-15.428-10.923 0-20.2 7.666-27.963 19.39L21.802 33.206Z" />
    <path fill="url(#meta__b)" d="M73.312 27.802c-10.923 0-20.2 7.666-27.963 19.39-10.976 16.568-17.698 41.245-17.698 64.944 0 9.775 2.146 17.28 4.95 21.82L9.027 149.482C2.973 139.413 0 126.202 0 111.148 0 83.772 7.514 55.24 21.802 33.206 34.48 13.666 52.774 0 73.757 0l-.445 27.802Z" />
  </svg>
) : useCustomBrandIcon && techSlug === 'gitlab' ? (
  <svg class={className} width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true">
    <path d="m31.46 12.78-.04-.12-4.35-11.35A1.14 1.14 0 0 0 25.94.6c-.24 0-.47.1-.66.24-.19.15-.33.36-.39.6l-2.94 9h-11.9l-2.94-9A1.14 1.14 0 0 0 6.07.58a1.15 1.15 0 0 0-1.14.72L.58 12.68l-.05.11a8.1 8.1 0 0 0 2.68 9.34l.02.01.04.03 6.63 4.97 3.28 2.48 2 1.52a1.35 1.35 0 0 0 1.62 0l2-1.52 3.28-2.48 6.67-5h.02a8.09 8.09 0 0 0 2.7-9.36Z" fill="#E24329" />
    <path d="m31.46 12.78-.04-.12a14.75 14.75 0 0 0-5.86 2.64l-9.55 7.24 6.09 4.6 6.67-5h.02a8.09 8.09 0 0 0 2.67-9.36Z" fill="#FC6D26" />
    <path d="m9.9 27.14 3.28 2.48 2 1.52a1.35 1.35 0 0 0 1.62 0l2-1.52 3.28-2.48-6.1-4.6-6.07 4.6Z" fill="#FCA326" />
    <path d="M6.44 15.3a14.71 14.71 0 0 0-5.86-2.63l-.05.12a8.1 8.1 0 0 0 2.68 9.34l.02.01.04.03 6.63 4.97 6.1-4.6-9.56-7.24Z" fill="#FC6D26" />
  </svg>
) : techIcon ? (
  <span class={`inline-flex items-center justify-center ${className}`} style={whiteFilterStyle}>
    <Icon name={techIcon} size={size} />
  </span>
) : localIconUrl ? (
  <img
    src={localIconUrl}
    alt={`${name} icon`}
    class={`inline-block object-contain ${className}`}
    style={whiteFilterStyle}
    width={size}
    height={size}
    loading="lazy"
    decoding="async"
  />
) : customPath ? (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
    <path d={customPath} />
  </svg>
) : (
  <svg
    class={className}
    width={size}
    height={size}
    viewBox="0 0 24 24"
    aria-hidden="true"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M4 7h16M4 12h16M4 17h10" />
  </svg>
)}
