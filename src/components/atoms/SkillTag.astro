---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<span
  class="inline-block px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-800/50 rounded-lg hover:border-red-400 dark:hover:border-red-600 hover:bg-red-100 dark:hover:bg-red-900/30 transition-all"
>
  {name}
</span>
