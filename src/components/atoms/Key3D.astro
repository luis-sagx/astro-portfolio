---
import TechIcon from './TechIcon.astro';
import { resolveTechBadgeColor, shouldUseWhiteBadgeIcon } from '../../utils/tech-icons';

interface Props {
  name: string;
  isWide?: boolean;
  widthUnits?: number;
  mini?: boolean;
}

const { name, isWide = false, widthUnits = 1, mini = false } = Astro.props;
const colors = resolveTechBadgeColor(name);
const useWhiteIcon = shouldUseWhiteBadgeIcon(name);
---

<div
  class={`key-3d ${isWide ? 'key-wide' : ''} ${mini ? 'key-mini' : ''}`}
  style={`--bg-color: ${colors.bg}; --fg-color: ${colors.fg}; --key-units: ${isWide ? 2 : widthUnits};`}
>
  <div class="key-back"></div>
  <div class="key-top">
    <span class="key-icon">
      <TechIcon name={name} size={mini ? 16 : 22} className="shrink-0" />
    </span>
  </div>
</div>

<style>
  .key-3d {
    --key-radius: 8px;
    --key-units: 1;
    --key-unit-size: 56px;
    --key-gap: 8px;
    --bg-color: #3b82f6;
    --fg-color: #ffffff;
    
    position: relative;
    display: inline-block;
    cursor: pointer;
  }

  .key-back {
    position: absolute;
    top: 0;
    left: 0;
    width: calc((var(--key-unit-size) * var(--key-units)) + (var(--key-gap) * (var(--key-units) - 1)));
    height: 56px;
    background: color-mix(in srgb, var(--bg-color) 55%, black);
    border-radius: var(--key-radius);
    transform: translate(4px, 7px);
    z-index: 0;
  }

  .key-top {
    position: relative;
    z-index: 1;
    padding: 12px;
    width: calc((var(--key-unit-size) * var(--key-units)) + (var(--key-gap) * (var(--key-units) - 1)));
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-color);
    border-radius: var(--key-radius);
    border: 2px solid rgba(255, 255, 255, 0.25);
    transition: transform 0.15s ease-out;
    box-shadow: 
      0 8px 18px color-mix(in srgb, var(--bg-color) 35%, black),
      0 0 15px rgba(59, 130, 246, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.3);
  }

  .key-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.2));
  }

  .key-3d:hover .key-top {
    transform: translate(2px, 5px);
  }

  :global(.dark) .key-top {
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow:
      0 0 20px rgba(59, 130, 246, 0.4),
      inset 0 1px 2px rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 640px) {
    .key-3d {
      --key-unit-size: 44px;
      --key-gap: 5px;
    }

    .key-top {
      height: 44px;
      padding: 10px;
    }

    .key-back {
      height: 44px;
      transform: translate(3px, 3px);
    }

    .key-icon {
      transform: scale(0.9);
    }
  }

  /* Mini variant for cards */
  .key-mini {
    --key-unit-size: 40px;
    --key-gap: 4px;
  }

  .key-mini .key-top {
    height: 40px;
    padding: 8px;
  }

  .key-mini .key-back {
    height: 40px;
    transform: translate(2px, 4px);
  }

  .key-mini .key-icon {
    transform: scale(0.75);
  }
</style>
