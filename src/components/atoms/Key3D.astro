---
import TechIcon from './TechIcon.astro';

interface Props {
  name: string;
  widthUnits?: number;
  tone?: 'center' | 'edge' | 'spacebar';
  mini?: boolean;
}

const { name, widthUnits = 1, tone = 'center', mini = false } = Astro.props;

const capVar = {
  center: 'var(--key-center)',
  edge: 'var(--key-edge)',
  spacebar: 'var(--spacebar)',
}[tone];
---

<div
  class:list={['key3', { 'key3--mini': mini }]}
  style={`--units: ${widthUnits}; --cap: ${capVar};`}
  data-tech={name}
  title={name}
>
  <span class="key3-front" aria-hidden="true"></span>
  <span class="key3-right" aria-hidden="true"></span>
  <span class="key3-cap">
    <TechIcon name={name} size={mini ? 16 : 24} className="shrink-0" />
  </span>
</div>

<style>
  @property --depth {
    syntax: '<length>';
    inherits: true;
    initial-value: 11px;
  }

  .key3 {
    --size: clamp(34px, 6vw, 58px);
    --gap: clamp(3px, 0.7vw, 6px);
    --depth: 11px;
    --units: 1;
    --cap: var(--key-center);

    position: relative;
    width: calc(var(--size) * var(--units) + var(--gap) * (var(--units) - 1));
    height: var(--size);
    cursor: pointer;
    transform-style: preserve-3d;
    transition: --depth 0.08s ease-out;
  }

  .key3-cap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cap);
    border-radius: var(--radius-md);
    transform: translateZ(var(--depth));
    box-shadow:
      inset 0 1px 0 oklch(1 0 0 / 0.25),
      inset 0 -1px 0 oklch(0 0 0 / 0.15);
  }

  .key3-front {
    position: absolute;
    left: 1px;
    right: 1px;
    top: 100%;
    height: var(--depth);
    transform-origin: top;
    transform: rotateX(90deg);
    background: color-mix(in oklch, var(--cap) 58%, black);
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
  }

  .key3-right {
    position: absolute;
    top: 1px;
    bottom: 1px;
    left: 100%;
    width: var(--depth);
    transform-origin: left;
    transform: rotateY(-90deg);
    background: color-mix(in oklch, var(--cap) 72%, black);
  }

  .key3:hover,
  .key3.is-pressed {
    --depth: 4px;
  }

  .key3--mini {
    --size: 34px;
    --gap: 3px;
    --depth: 6px;
  }

  .key3--mini:hover,
  .key3--mini.is-pressed {
    --depth: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .key3 {
      transition: none;
    }
  }
</style>
